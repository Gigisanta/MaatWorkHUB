{
  "name": "maatwork-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "pre-dev": "tsx scripts/pre-dev.ts",
    "dev": "pnpm pre-dev && turbo run dev --filter=studio",
    "dev:studio": "turbo run dev --filter=studio",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "db:push": "pnpm --filter @maatwork/database db:push",
    "db:studio": "pnpm --filter @maatwork/database db:studio",
    "seed": "pnpm --filter @maatwork/database seed",
    "clean": "tsx scripts/clean.ts",
    "create-app": "tsx scripts/create-app.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.3.5",
    "jsdom": "^28.1.0",
    "prettier": "^3.4.2",
    "tsx": "^4.7.2",
    "turbo": "^2.4.2",
    "typescript": "^5.7.3",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  }
}
